{
  "compilerOptions": {
    "baseUrl": "./src",
    "jsx": "react",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "components/*": ["components/*"],
      "pages/*": ["pages/*"],
      "contexts/*": ["contexts/*"],
      "utils/*": ["utils/*"],
      "styles/*": ["styles/*"]
    }
  },
  "include": ["src"]
}
